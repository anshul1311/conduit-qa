# Conduit QA Framework — environment configuration
# Copy to .env and adjust if your app runs on different ports.

# React frontend (the package.json in the SUT pins this to 4101).
UI_BASE_URL=http://localhost:4101

# Express backend (the /api prefix is added by the API client).
API_BASE_URL=http://localhost:3000

# Optional: set a seed to make factory output deterministic across runs.
# Leaving this unset uses Date.now() so parallel runs stay collision-free.
# TEST_SEED=42
